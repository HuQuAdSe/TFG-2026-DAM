<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.voluntariadomadrid.views.analytics.AnalyticsController"
      spacing="20"
      style="-fx-background-color: #f4f6f8; -fx-padding: 32;">

    <!-- Cabecera -->
    <VBox spacing="4">
        <Label text="Panel de analiticas"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Ofertas de tu organizacion por estado"
               style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
    </VBox>

    <!-- Mensaje de estado mientras carga -->
    <Label fx:id="statusLabel"
           text="Cargando datos..."
           style="-fx-font-size: 13px; -fx-text-fill: #666;"/>

    <!-- Grafica de barras -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 10;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

        <BarChart fx:id="ofertasChart"
                  VBox.vgrow="ALWAYS"
                  legendVisible="false">
            <xAxis>
                <CategoryAxis label="Estado"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Numero de ofertas" minorTickVisible="false"/>
            </yAxis>
        </BarChart>

    </VBox>

</VBox>