<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Vista de bienvenida que se carga por defecto en el dashboard -->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.voluntariadomadrid.views.HomeController"
      alignment="CENTER" spacing="16"
      style="-fx-padding: 40;">

    <!-- Saludo personalizado con el nombre del usuario -->
    <Label fx:id="welcomeLabel"
           text="Bienvenido"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

    <!-- Nombre de la organizacion -->
    <Label fx:id="orgLabel"
           text=""
           style="-fx-font-size: 16px; -fx-text-fill: #666;"/>

    <!-- Separador visual -->
    <Region prefHeight="20"/>

    <!-- Tarjetas de resumen -->
    <HBox spacing="20" alignment="CENTER">

        <!-- Tarjeta: ofertas activas -->
        <VBox alignment="CENTER" spacing="8" prefWidth="180" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <Label fx:id="ofertasActivasLabel"
                   text="0"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3f51b5;"/>
            <Label text="Ofertas activas"
                   style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
        </VBox>

        <!-- Tarjeta: total inscritos -->
        <VBox alignment="CENTER" spacing="8" prefWidth="180" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <Label fx:id="totalInscritosLabel"
                   text="0"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #43a047;"/>
            <Label text="Voluntarios inscritos"
                   style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
        </VBox>

        <!-- Tarjeta: ofertas completadas -->
        <VBox alignment="CENTER" spacing="8" prefWidth="180" prefHeight="120"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <Label fx:id="ofertasCompletadasLabel"
                   text="0"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #fb8c00;"/>
            <Label text="Ofertas completadas"
                   style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
        </VBox>

    </HBox>

</VBox>